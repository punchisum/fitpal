{
  "name": "fitpal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "typecheck:trigger": "tsc -p tsconfig.trigger.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:verify": "node scripts/db-verify.mjs",
    "test:rls": "node scripts/test-rls.mjs",
    "test:flow": "node scripts/test-flow.mjs",
    "worker:dev": "wrangler dev -c wrangler.telegram.jsonc",
    "worker:deploy": "wrangler deploy -c wrangler.telegram.jsonc",
    "trigger:dev": "trigger.dev dev",
    "trigger:deploy": "trigger.dev deploy",
    "guard": "node scripts/check-no-private.mjs",
    "verify": "npm run guard && npm run typecheck && npm run typecheck:trigger && npm run test",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "test:onboarding": "node scripts/test-onboarding.mjs",
    "test:telegram": "node scripts/test-telegram.mjs",
    "test:food": "node scripts/test-food.mjs",
    "test:checkin": "node scripts/test-checkin.mjs",
    "test:draft": "node scripts/test-draft.mjs",
    "test:health": "node scripts/test-health.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@trigger.dev/build": "4.4.6",
    "@trigger.dev/sdk": "4.4.6",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "pg": "^8.13.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.103.0"
  }
}
