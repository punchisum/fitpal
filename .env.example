# fitpal — Public Fitness Agent env template (NAMES ONLY — safe to commit).
# Copy to .env.local and fill real values. .env.local is gitignored.

# ───────── Supabase (NEW public project — never the private one) ─────────
# Client-safe: URL + anon/publishable key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — never import into client/browser code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ───────── Telegram (NEW public bot, separate from private) ─────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ───────── LLM (server-side only) ─────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# OPENAI_API_KEY=   # optional, deferred

# ───────── Trigger.dev (NEW public project) ─────────
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
PRODUCTION_TRIGGER_SECRET_KEY=

# ───────── App-internal secrets (generate: openssl rand -hex 32) ─────────
INTERNAL_JOB_SECRET=
RATE_LIMIT_SECRET=
APP_ENCRYPTION_KEY=

# ───────── App config ─────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ───────── Cloudflare (provision in dashboard) ─────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ───────── Owner signup alerts (optional; set as Telegram Worker secrets) ─────────
# A separate admin bot DMs the owner on each new signup. No-op if unset.
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=
